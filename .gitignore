services/web/tmp/
services/web/public/assets/
services/web/storage/

## Python (services/ml)
services/ml/__pycache__/
services/ml/.venv/
services/ml/venv/
services/ml/*.pyc
services/ml/.pytest_cache/

## Jupyter
services/ml/notebooks/.ipynb_checkpoints/

## IDE
.vscode/
.idea/
*.swp
*.swo
*~

## OS
.DS_Store
Thumbs.db

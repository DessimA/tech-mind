# ============================================
# TechMind - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# --- PostgreSQL ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=techmind
DB_PASSWORD=techmind_dev
DB_NAME=techmind_dev

# --- Valkey (Redis OSS) ---
REDIS_HOST=valkey
REDIS_PORT=6379

# --- Rails ---
SECRET_KEY_BASE=change-me-in-production
RAILS_MAX_THREADS=1
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true

# --- ML Service ---
ML_HOST=ml
ML_PORT=8000
MODEL_VERSION=v4
ML_TIMEOUT=8

# --- Groq (Fallback LLM) ---
GROQ_API_KEY=change-me
GROQ_TIMEOUT=5
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=1024

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_PERIOD=60
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_PERIOD=60

# --- Cache ---
CACHE_TTL=300

# --- Test Database ---
DB_TEST_NAME=techmind_test

# ============================================
# TechMind - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# --- LocalStack ---
LOCALSTACK_AUTH_TOKEN=seu-token-aqui
AWS_ENDPOINT=http://localstack:4566
AWS_REGION=us-east-1

# --- PostgreSQL ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=techmind
DB_PASSWORD=techmind_dev
DB_NAME=techmind_dev

# --- Valkey (Redis OSS) ---
REDIS_HOST=valkey
REDIS_PORT=6379

# --- Rails ---
SECRET_KEY_BASE=change-me-in-production
RAILS_MAX_THREADS=5
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true

# --- ML Service ---
ML_THRESHOLD=0.5
MODEL_VERSION=v1

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_PERIOD=60

# --- Cache ---
CACHE_TTL=300

# --- Sidekiq ---
SIDEKIQ_RETRY_MAX=3
SIDEKIQ_CONCURRENCY=5

# --- Test Database ---
DB_TEST_NAME=techmind_test

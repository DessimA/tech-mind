<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= content_for?(:title) ? "#{yield(:title)} - TechMind" : "TechMind" %></title>
  <meta name="turbo-cache-control" content="no-cache">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
  <nav class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <div class="flex items-center space-x-8">
          <%= link_to "TechMind", conteudos_path, class: "text-xl font-bold text-indigo-600" %>
          <% if logged_in? %>
            <%= link_to "Conteúdos", conteudos_path, class: "text-sm font-medium text-gray-700 hover:text-indigo-600" %>
            <%= link_to "Novo", new_conteudo_path, class: "px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700" %>
          <% end %>
        </div>
        <div class="flex items-center space-x-4">
          <% if logged_in? %>
            <span class="text-sm text-gray-500"><%= current_user.nome %></span>
            <%= button_to "Sair", logout_path, method: :post, class: "text-sm text-gray-500 hover:text-red-600" %>
          <% else %>
            <%= link_to "Login", login_path, class: "text-sm text-gray-700 hover:text-indigo-600" %>
            <%= link_to "Cadastrar", register_path, class: "px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700" %>
          <% end %>
        </div>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-1">
    <% if notice %>
      <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm" data-turbo-temporary>
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm" data-turbo-temporary>
        <%= alert %>
      </div>
    <% end %>

    <%= yield %>
  </main>

  <footer class="bg-white border-t border-gray-200 py-4 mt-auto">
    <div class="max-w-7xl mx-auto px-4 text-center text-xs text-gray-400">
      TechMind MVP &mdash; Organização Inteligente de Conhecimento
    </div>
  </footer>
</body>
</html>

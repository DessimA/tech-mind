<% content_for :title, "Conteúdos" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-display text-accent-green uppercase tracking-wide">Meus Conteúdos</h1>
  <%= link_to "Novo Conteúdo", new_conteudo_path,
      class: "px-4 py-2 text-sm font-bold text-ink bg-accent-green border-2 border-ink sticker-shadow hover:-translate-y-0.5 hover:translate-x-0.5 active:translate-x-0 active:translate-y-0 transition-all" %>
</div>

<%= form_tag conteudos_path, method: :get, class: "mb-6 flex gap-2" do %>
  <%= text_field_tag :q, params[:q], placeholder: "Buscar por título ou palavra-chave...",
      class: "flex-1 px-4 py-2 bg-surface border-b-2 border-[#A9AFBC]/30 text-[#F4F1E8] rounded-lg focus:border-accent-cyan focus:outline-none transition-colors text-sm placeholder:text-[#A9AFBC]/40" %>
  <%= select_tag :sort, options_for_select([
        ["Mais recentes", "created_at_desc"],
        ["Mais antigos", "created_at_asc"],
        ["Título A-Z", "titulo_asc"]
      ], params[:sort]), class: "px-3 py-2 bg-surface border-b-2 border-[#A9AFBC]/30 text-[#F4F1E8] rounded-lg focus:border-accent-cyan focus:outline-none transition-colors text-sm" %>
  <%= submit_tag "Buscar", class: "px-4 py-2 text-sm font-bold text-ink bg-accent-mustard border-2 border-ink sticker-shadow hover:-translate-y-0.5 active:translate-y-0 transition-all cursor-pointer" %>
<% end %>

<% if @conteudos.empty? %>
  <div class="text-center py-16 bg-surface border-2 border-ink sticker-shadow rounded-lg halftone-bg">
    <p class="text-[#A9AFBC] font-accent text-xl tracking-wide">Nenhum conteúdo cadastrado ainda.</p>
    <%= link_to "Cadastre o primeiro conteúdo", new_conteudo_path,
        class: "mt-3 inline-block text-accent-cyan hover:text-accent-green transition-colors font-medium glitch-hover" %>
  </div>
<% else %>
  <div class="bg-surface border-2 border-ink sticker-shadow rounded-lg overflow-hidden">
    <table class="min-w-full">
      <thead>
        <tr class="bg-surface-alt border-b-2 border-ink">
          <th class="px-6 py-3 text-left text-xs font-mono uppercase tracking-wider text-[#A9AFBC]">Título</th>
          <th class="px-6 py-3 text-left text-xs font-mono uppercase tracking-wider text-[#A9AFBC]">Categoria</th>
          <th class="px-6 py-3 text-left text-xs font-mono uppercase tracking-wider text-[#A9AFBC]">Status</th>
          <th class="px-6 py-3 text-left text-xs font-mono uppercase tracking-wider text-[#A9AFBC]">Data</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink">
        <% @conteudos.each do |c| %>
          <tr class="hover:bg-surface-alt/50 transition-colors">
            <td class="px-6 py-4 text-sm font-medium text-[#F4F1E8]"><%= c.titulo %></td>
            <td class="px-6 py-4">
              <% if c.status == "done" && c.categoria.present? %>
                <span class="px-2 py-1 text-xs font-mono uppercase tracking-wider text-ink bg-accent-cyan sticker-shadow-sm">
                  <%= c.categoria %>
                </span>
              <% else %>
                <span class="text-[#A9AFBC]/50 font-mono text-xs">—</span>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <% if c.status == "processing" %>
                <span class="px-2 py-1 text-xs font-mono uppercase tracking-wider text-ink bg-accent-mustard sticker-shadow-sm">Processando</span>
              <% elsif c.status == "done" %>
                <span class="px-2 py-1 text-xs font-mono uppercase tracking-wider text-ink bg-accent-green sticker-shadow-sm">Concluído</span>
              <% elsif c.status == "failed" %>
                <span class="px-2 py-1 text-xs font-mono uppercase tracking-wider text-ink bg-accent-magenta sticker-shadow-sm">Falhou</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm font-mono text-[#A9AFBC]">
              <%= l(c.created_at, format: :short) rescue c.created_at.strftime("%d/%m/%Y") %>
            </td>
            <td class="px-6 py-4 text-right">
              <%= link_to "Detalhes", c, class: "text-accent-cyan hover:text-accent-green transition-colors text-sm font-mono uppercase tracking-wider glitch-hover" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @conteudos.respond_to?(:total_pages) && @conteudos.total_pages > 1 %>
    <div class="mt-6 flex justify-center space-x-2">
      <% (1..@conteudos.total_pages).each do |i| %>
        <%= link_to i, conteudos_path(page: i, q: params[:q], sort: params[:sort]),
            class: "px-3 py-2 text-sm font-mono border-2 border-ink transition-all #{i == @conteudos.current_page ? 'bg-accent-green text-ink sticker-shadow' : 'bg-surface text-[#A9AFBC] hover:bg-surface-alt'}" %>
      <% end %>
    </div>
  <% end %>
<% end %>

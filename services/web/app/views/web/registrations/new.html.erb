<% content_for :title, "Cadastro" %>

<div class="max-w-md mx-auto mt-12">
  <h1 class="text-3xl font-display text-accent-cyan uppercase tracking-wide mb-6 text-center">
    Criar Conta
  </h1>

  <%= form_with model: @user, url: register_path, class: "bg-surface border-2 border-ink sticker-shadow rounded-lg p-6 space-y-5" do |f| %>
    <div>
      <%= f.label :nome, "Nome", class: "block text-sm font-medium text-[#F4F1E8] mb-1" %>
      <%= f.text_field :nome, required: true, maxlength: 100,
            class: "w-full px-3 py-2 bg-surface-alt border-b-2 border-[#A9AFBC]/30 text-[#F4F1E8] rounded-lg focus:border-accent-cyan focus:outline-none transition-colors text-sm placeholder:text-[#A9AFBC]/40",
            placeholder: "Seu nome" %>
    </div>

    <div>
      <%= f.label :email, "Email", class: "block text-sm font-medium text-[#F4F1E8] mb-1" %>
      <%= f.email_field :email, required: true,
            class: "w-full px-3 py-2 bg-surface-alt border-b-2 border-[#A9AFBC]/30 text-[#F4F1E8] rounded-lg focus:border-accent-cyan focus:outline-none transition-colors text-sm placeholder:text-[#A9AFBC]/40",
            placeholder: "seu@email.com" %>
    </div>

    <div>
      <%= f.label :password, "Senha", class: "block text-sm font-medium text-[#F4F1E8] mb-1" %>
      <%= f.password_field :password, required: true, minlength: 6,
            class: "w-full px-3 py-2 bg-surface-alt border-b-2 border-[#A9AFBC]/30 text-[#F4F1E8] rounded-lg focus:border-accent-cyan focus:outline-none transition-colors text-sm placeholder:text-[#A9AFBC]/40",
            placeholder: "Mínimo 6 caracteres" %>
    </div>

    <%= f.submit "Criar Conta", class: "w-full px-4 py-2.5 text-sm font-bold text-ink bg-accent-green border-2 border-ink sticker-shadow hover:-translate-y-0.5 active:translate-y-0 transition-all cursor-pointer uppercase tracking-wide" %>
  <% end %>

  <p class="text-center text-sm text-[#A9AFBC] mt-4">
    Já tem conta? <%= link_to "Faça login", login_path, class: "text-accent-cyan hover:text-accent-green transition-colors font-medium glitch-hover" %>
  </p>
</div>

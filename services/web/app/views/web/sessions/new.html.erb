<% content_for :title, "Login" %>
<% content_for :hide_nav, true if content_for?(:hide_nav) %>

<div class="max-w-md mx-auto mt-12">
  <h1 class="text-3xl font-display text-accent-green uppercase tracking-wide mb-6 text-center">
    Entrar
  </h1>

  <%= form_tag login_path, class: "bg-surface border-2 border-ink sticker-shadow rounded-lg p-6 space-y-5" do %>
    <div>
      <%= label_tag :email, "Email", class: "block text-sm font-medium text-[#F4F1E8] mb-1" %>
      <%= email_field_tag :email, params[:email], required: true,
            class: "w-full px-3 py-2 bg-surface-alt border-b-2 border-[#A9AFBC]/30 text-[#F4F1E8] rounded-lg focus:border-accent-cyan focus:outline-none transition-colors text-sm placeholder:text-[#A9AFBC]/40",
            placeholder: "seu@email.com" %>
    </div>

    <div>
      <%= label_tag :password, "Senha", class: "block text-sm font-medium text-[#F4F1E8] mb-1" %>
      <%= password_field_tag :password, nil, required: true,
            class: "w-full px-3 py-2 bg-surface-alt border-b-2 border-[#A9AFBC]/30 text-[#F4F1E8] rounded-lg focus:border-accent-cyan focus:outline-none transition-colors text-sm placeholder:text-[#A9AFBC]/40",
            placeholder: "Sua senha" %>
    </div>

    <%= submit_tag "Entrar", class: "w-full px-4 py-2.5 text-sm font-bold text-ink bg-accent-green border-2 border-ink sticker-shadow hover:-translate-y-0.5 active:translate-y-0 transition-all cursor-pointer uppercase tracking-wide" %>
  <% end %>

  <p class="text-center text-sm text-[#A9AFBC] mt-4">
    Não tem conta? <%= link_to "Cadastre-se", register_path, class: "text-accent-cyan hover:text-accent-green transition-colors font-medium glitch-hover" %>
  </p>
</div>
